# Server port
PORT=3000

# Anthropic API key (required for AI chat features)
ANTHROPIC_API_KEY=

# Directory for uploaded files (relative or absolute path)
UPLOAD_DIR=public/uploads

# Maximum file upload size in bytes (default: 10MB)
MAX_FILE_SIZE=10485760

# Allowed CORS origin (default: * in dev)
CORS_ORIGIN=*

# Admin token for accessing /admin dashboard (required to enable admin page)
ADMIN_TOKEN=

# LLM Gateway key for image transformation (required for POST /transform)
LLM_GATEWAY_KEY=

# LLM Gateway URL (default: https://llm.yester.cloud)
LLM_GATEWAY_URL=https://llm.yester.cloud
